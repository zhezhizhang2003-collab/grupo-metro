  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <span class="text-brand-red text-xs sm:text-sm tracking-[.3em] uppercase">Contacto</span>
    <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl mt-4 mb-16 leading-[1.05] uppercase">Dónde Estamos</h2>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-16">
      <div class="space-y-8">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-brand-red/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div>
            <h3 class="text-white font-semibold text-sm tracking-wide mb-1.5">Dirección</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">Polígono Francolí Parcela 15, Nave 5<br>Tarragona 43006</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-green-500/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <h3 class="text-white font-semibold text-sm tracking-wide mb-1.5">WhatsApp Pedidos</h3>
            <a href="https://wa.me/34600781881" target="_blank" rel="noopener noreferrer"
              class="text-brand-red hover:text-brand-red-light transition-colors text-lg font-semibold">+34 600 781 881</a>
            <p class="text-zinc-500 text-xs mt-1">Respuesta rápida garantizada</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-zinc-800 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-zinc-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <div>
            <h3 class="text-white font-semibold text-sm tracking-wide mb-1.5">Datos Fiscales</h3>
            <p class="text-zinc-400 text-sm">Mehar Company SL</p>
            <p class="text-zinc-500 text-xs">CIF: B05412028</p>
          </div>
        </div>
      </div>

      <!-- Mapa -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden min-h-[280px] relative">
        <iframe
          src="https://maps.google.com/maps?q=Polígono+Francolí+Parcela+15+Tarragona&amp;output=embed"
          width="100%" height="100%"
          style="border:0; min-height: 280px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
