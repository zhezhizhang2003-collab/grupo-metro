---
import Layout from '../layouts/Layout.astro';

const marcas = [
  'Coca-Cola', 'Fanta', 'Nestea', 'Nestlé', 'Red Bull', 'Heineken', 'Corona', 'Guinness',
  'Estrella Damm', 'Estrella Galicia', 'Budweiser', 'Desperados', 'Evian', 'Font Vella',
  'Alhambra', 'Voll-Damm', 'Don Simon', 'Granini', 'Juver', 'Viladrau', 'Bezoya', 'San Pellegrino',
  'Brugal', 'Coors', 'Kopparberg', 'Strongbow', 'Bodega Pinord', 'Solán de Cabras',
  'Vichy Catalan', 'Larios', 'Magners', 'Powerking', 'San Miguel', 'Mahou', 'Perrier'
];
const marcasDoble = [...marcas, ...marcas];

// Logos — prefiere SVG (vectorial, más nítido), fallback a PNG
const logoUrl = (marca: string) => {
  const file = marca.replace(/ /g, '-').replace(/ñ/g, 'n').replace(/é/g, 'e').replace(/á/g, 'a').replace(/ó/g, 'o').replace(/í/g, 'i').replace(/ú/g, 'u').replace(/'/g, '');
  // SVG: vectoriales, siempre nítidos a cualquier tamaño
  const logosSvg = ['Coca-Cola','Heineken'];
  // PNG: logos rasterizados a 200px
  const logosPng = [
    'Alhambra','Bezoya','Bodega-Pinord','Brugal','Budweiser','Coors','Corona','Desperados',
    'Don-Simon','Estrella-Damm','Estrella-Galicia','Evian','Fanta','Font-Vella',
    'Granini','Guinness','Juver','Kopparberg','Larios','Magners','Nestea','Nestle',
    'Powerking','Red-Bull','San-Miguel','San-Pellegrino','Solan-de-Cabras',
    'Strongbow','Vichy-Catalan','Viladrau','Mahou','Perrier','Voll-Damm'
  ];
  if (logosSvg.includes(file)) return `/logos/${file}.svg`;
  if (logosPng.includes(file)) return `/logos/${file}.png`;
  return null;
};
---

<Layout
  title="Inicio"
  description="Grupo METRO — Distribución de bebidas a restauración y supermercados en Tarragona. +50 marcas líderes. Coca-Cola, Estrella Damm, Heineken, Red Bull y más."
>

<!-- Hero -->
<section class="hero-bg min-h-screen flex items-center pt-16">
  <div class="max-w-7xl mx-auto px-4 w-full">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="text-amber-400 text-sm tracking-[.3em] uppercase">Distribución · Tarragona</span>
        <h1 class="font-display text-6xl md:text-8xl leading-none mt-4 text-balance">
          LÍDERES EN<br>
          <span class="text-amber-400">DISTRIBUCIÓN</span>
        </h1>
        <p class="text-zinc-400 mt-6 text-lg max-w-md">
          Llevamos las mejores marcas a restaurantes, bares y supermercados de Tarragona.
          Coca-Cola, Estrella Damm, Heineken, Red Bull y mucho más.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-8">
          <a href="/catalogo" class="bg-amber-400 text-black px-8 py-4 font-semibold tracking-wider uppercase text-sm text-center hover:bg-amber-300 transition">
            Ver Catálogo
          </a>
          <a href="https://wa.me/34600781881" class="border border-zinc-700 px-8 py-4 text-sm tracking-wider uppercase text-center hover:border-amber-400 transition">
            WhatsApp
          </a>
        </div>
      </div>
      <div class="hidden md:block">
        <img
          src="/logo.jpg"
          alt="Grupo Metro Logo"
          class="w-full max-w-sm mx-auto rounded-2xl opacity-90"
          width="400" height="200"
          loading="eager"
        />
        <div class="grid grid-cols-3 gap-3 mt-8">
          <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-lg p-3 text-center text-xs text-zinc-400">Coca-Cola</div>
          <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-lg p-3 text-center text-xs text-zinc-400">Estrella Damm</div>
          <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-lg p-3 text-center text-xs text-zinc-400">Heineken</div>
          <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-lg p-3 text-center text-xs text-zinc-400">Red Bull</div>
          <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-lg p-3 text-center text-xs text-zinc-400">Nestlé</div>
          <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-lg p-3 text-center text-xs text-zinc-400">Font Vella</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Quiénes Somos -->
<section class="py-24 bg-black">
  <div class="max-w-7xl mx-auto px-4">
    <span class="text-amber-400 text-sm tracking-[.3em] uppercase">Quiénes Somos</span>
    <h2 class="font-display text-5xl mt-4 text-balance">DISTRIBUCIÓN QUE<br>IMPULSA TU NEGOCIO</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mt-12">
      <div class="border-l-2 border-amber-400 pl-6">
        <div class="text-3xl font-display text-amber-400">+50</div>
        <p class="text-zinc-400 mt-2 text-sm">Marcas oficiales con las que colaboramos directamente</p>
      </div>
      <div class="border-l-2 border-amber-400 pl-6">
        <div class="text-3xl font-display text-amber-400">Tarragona</div>
        <p class="text-zinc-400 mt-2 text-sm">Cobertura completa en restauración, bares y supermercados</p>
      </div>
      <div class="border-l-2 border-amber-400 pl-6">
        <div class="text-3xl font-display text-amber-400">24/7</div>
        <p class="text-zinc-400 mt-2 text-sm">Pedidos por WhatsApp con respuesta ágil y entrega rápida</p>
      </div>
    </div>
  </div>
</section>

<!-- Marcas — Marquee animado -->
<section class="py-24 bg-zinc-950 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 mb-12">
    <span class="text-amber-400 text-sm tracking-[.3em] uppercase">Colaboraciones Oficiales</span>
    <h2 class="font-display text-5xl mt-4">MARCAS QUE DISTRIBUIMOS</h2>
  </div>

  <div class="marquee-pause py-10 border-y border-zinc-800/50">
    <div class="animate-marquee flex gap-6 w-max">
      {marcasDoble.map((marca, i) => {
        const url = logoUrl(marca);
        return (
          <div class="bg-zinc-900 border border-zinc-800 rounded-xl px-10 py-8 flex flex-col items-center gap-5 whitespace-nowrap hover:border-amber-400/50 transition shrink-0 min-w-[170px]">
            <img src={url} alt={marca} class="h-32 w-auto object-contain" loading="lazy" />
            <span class="text-xs text-zinc-500 font-medium tracking-wide">{marca}</span>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- Catálogo CTA -->
<section class="py-24 bg-amber-400 text-black">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h2 class="font-display text-5xl md:text-7xl">CATÁLOGO JUNIO 2026</h2>
    <p class="text-lg mt-4 max-w-xl mx-auto opacity-80">
      Explora todos nuestros productos con precios actualizados. Nuevas incorporaciones cada mes.
    </p>
    <a href="/catalogo" class="inline-block bg-black text-amber-400 px-10 py-5 mt-8 font-semibold tracking-wider uppercase text-sm hover:bg-zinc-900 transition">
      Ver Catálogo Completo
    </a>
  </div>
</section>

<!-- Contacto -->
<section id="contacto" class="py-24 bg-black">
  <div class="max-w-7xl mx-auto px-4">
    <span class="text-amber-400 text-sm tracking-[.3em] uppercase">Contacto</span>
    <h2 class="font-display text-5xl mt-4 mb-12">DÓNDE ESTAMOS</h2>
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <div class="space-y-6 text-zinc-400">
          <div>
            <h3 class="text-white font-semibold mb-1">Dirección</h3>
            <p>Polígono Francolí Parcela 15, Nave 5<br>Tarragona 43006</p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-1">WhatsApp Pedidos</h3>
            <a href="https://wa.me/34600781881" class="text-amber-400 hover:text-amber-300 transition text-lg">+34 600 781 881</a>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-1">Datos Fiscales</h3>
            <p>Mehar Company SL<br>CIF: B05412028</p>
          </div>
        </div>
      </div>
      <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 flex items-center justify-center min-h-[250px]">
        <div class="text-center text-zinc-500">
          <span class="text-4xl block mb-2">📍</span>
          Polígono Francolí Parcela 15, Nave 5<br>Tarragona 43006
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>
