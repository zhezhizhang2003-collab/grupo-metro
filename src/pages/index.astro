---
import Layout from '../layouts/Layout.astro';

const sinAlcohol = [
  'Coca-Cola','Fanta','Nestea','Nestlé','Don Simon','Granini','Juver',
  'Evian','Font Vella','Bezoya','San Pellegrino','Solán de Cabras','Viladrau','Vichy Catalan','Perrier'
];
const conAlcohol = [
  'Heineken','Corona','Guinness','Estrella Damm','Estrella Galicia','Budweiser','Desperados',
  'Alhambra','Voll-Damm','San Miguel','Mahou','Coors',
  'Red Bull','Powerking',
  'Brugal','Larios','Bodega Pinord','Kopparberg','Strongbow','Magners'
];

const logoUrl = (marca: string) => {
  const file = marca.replace(/ /g, '-').replace(/ñ/g, 'n').replace(/é/g, 'e').replace(/á/g, 'a').replace(/ó/g, 'o').replace(/í/g, 'i').replace(/ú/g, 'u').replace(/'/g, '');
  const logosSvg = [
    'Alhambra','Budweiser','Coca-Cola','Coors','Corona','Desperados',
    'Estrella-Damm','Estrella-Galicia','Evian','Fanta','Granini','Guinness',
    'Heineken','Kopparberg','Mahou','Nestea','Nestle','Perrier',
    'Red-Bull','San-Miguel','San-Pellegrino'
  ];
  const logosPng = [
    'Bezoya','Bodega-Pinord','Brugal','Don-Simon','Font-Vella','Juver','Larios',
    'Magners','Powerking','Solan-de-Cabras','Strongbow','Vichy-Catalan','Viladrau','Voll-Damm'
  ];
  if (logosSvg.includes(file)) return `/logos/${file}.svg`;
  if (logosPng.includes(file)) return `/logos/${file}.png`;
  return null;
};
---

<Layout
  title="Inicio"
  description="Grupo METRO — Distribución de bebidas a restauración y supermercados en Tarragona. +50 marcas líderes: Coca-Cola, Estrella Damm, Heineken, Red Bull y más."
  ogImage="/logo.jpg"
>

<!-- ════════════════════ HERO — Dark ════════════════════ -->
<section class="hero-bg min-h-[calc(100vh-4rem)] flex items-center relative overflow-hidden">
  <!-- Línea geométrica sutil en lugar de orb -->
  <div class="absolute top-0 right-0 w-96 h-96 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 400 400" class="w-full h-full opacity-[0.04]">
      <line x1="400" y1="0" x2="0" y2="400" stroke="#d9445a" stroke-width="1" />
      <line x1="350" y1="0" x2="0" y2="350" stroke="#5856c0" stroke-width="1" />
    </svg>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-16 md:py-24 relative z-10 text-center">
    <div class="reveal">
      <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 mb-8">
        <span class="w-2 h-2 rounded-full bg-brand-red"></span>
        <span class="text-zinc-300 text-xs tracking-wider uppercase font-medium">Distribución · Tarragona</span>
      </div>

      <h1 class="font-display text-6xl sm:text-7xl lg:text-8xl leading-[0.95] text-balance uppercase tracking-tight">
        Líderes en<br>
        <span class="text-brand-red">Distribución</span>
      </h1>

      <p class="text-zinc-400 mt-6 text-base sm:text-lg max-w-xl mx-auto leading-relaxed">
        Llevamos las mejores marcas a restaurantes, bares y supermercados de Tarragona desde hace más de 15 años.
      </p>

      <!-- Badges de confianza -->
      <div class="flex flex-wrap justify-center gap-3 mt-10">
        <span class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-xs text-zinc-300 font-medium">
          <svg class="w-3.5 h-3.5 text-brand-red shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Distribuidor oficial
        </span>
        <span class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-xs text-zinc-300 font-medium">
          <svg class="w-3.5 h-3.5 text-brand-red shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
          Entrega en Tarragona
        </span>
        <span class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-xs text-zinc-300 font-medium">
          <svg class="w-3.5 h-3.5 text-brand-red shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Respuesta rápida
        </span>
      </div>
    </div>
  </div>

  <!-- Scroll arrow -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 pointer-events-none" aria-hidden="true">
    <svg class="w-6 h-6 text-white/20 animate-bounce" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>

<!-- ════════════════════ QUIÉNES SOMOS — Blanco ════════════════════ -->
<section id="quienes-somos" class="py-20 sm:py-28 bg-[var(--color-light)] relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-14">
      <span class="text-brand-red text-xs sm:text-sm tracking-[.3em] uppercase font-semibold">Quiénes Somos</span>
      <h2 class="font-display text-3xl sm:text-5xl text-[var(--color-text-dark)] mt-3 leading-[1.1] uppercase tracking-tight">
        Distribución que impulsa<br>tu negocio
      </h2>
      <p class="text-[var(--color-text-muted)] text-base sm:text-lg max-w-2xl mt-4 leading-relaxed">
        Somos el puente entre las grandes marcas y tu establecimiento. Rapidez, cercanía y un catálogo que no para de crecer.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 lg:gap-8 reveal">
      <div class="bg-white border border-[var(--color-light-border)] rounded-xl p-6 sm:p-8 shadow-[var(--shadow-md)] hover:shadow-[var(--shadow-lg)] hover:border-brand-red/20 transition-all duration-300">
        <div class="w-12 h-12 rounded-lg bg-brand-red/5 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        </div>
        <div class="text-4xl font-display text-brand-red mb-2">+50</div>
        <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">Marcas oficiales con las que colaboramos directamente, desde refrescos hasta licores premium.</p>
      </div>
      <div class="bg-white border border-[var(--color-light-border)] rounded-xl p-6 sm:p-8 shadow-[var(--shadow-md)] hover:shadow-[var(--shadow-lg)] hover:border-brand-blue/20 transition-all duration-300">
        <div class="w-12 h-12 rounded-lg bg-brand-blue/5 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div class="text-4xl font-display text-brand-blue mb-2">Tarragona</div>
        <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">Cobertura completa en toda la provincia: restauración, bares, supermercados y tiendas de conveniencia.</p>
      </div>
      <div class="bg-white border border-[var(--color-light-border)] rounded-xl p-6 sm:p-8 shadow-[var(--shadow-md)] hover:shadow-[var(--shadow-lg)] hover:border-brand-red/20 transition-all duration-300">
        <div class="w-12 h-12 rounded-lg bg-brand-red/5 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div class="text-4xl font-display text-brand-red mb-2">24/7</div>
        <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">Pedidos por WhatsApp con respuesta ágil. Tu negocio no espera, nosotros tampoco.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════ MARCAS — Gris claro, Grid estático ════════════════════ -->
<section id="marcas" class="py-20 sm:py-28 bg-[var(--color-light-alt)] relative">
  <div class="absolute inset-0 accent-dots" aria-hidden="true"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid md:grid-cols-3 gap-12 lg:gap-16">
      <!-- Columna de texto -->
      <div class="md:col-span-1 reveal">
        <span class="text-brand-red text-xs sm:text-sm tracking-[.3em] uppercase font-semibold">Colaboraciones Oficiales</span>
        <h2 class="font-display text-3xl sm:text-4xl text-[var(--color-text-dark)] mt-3 mb-4 leading-[1.1] uppercase tracking-tight">
          Marcas que<br>Distribuimos
        </h2>
        <p class="text-[var(--color-text-muted)] text-sm leading-relaxed mb-6">
          Trabajamos directamente con más de 50 marcas líderes. Si no encuentras lo que buscas, consúltanos.
        </p>
        <a href="/catalogo" class="inline-flex items-center gap-1 text-brand-red text-sm font-semibold hover:text-brand-red-dark transition-colors">
          Ver catálogo completo <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <!-- Grid de logos -->
      <div class="md:col-span-2 space-y-10 reveal">
        <!-- Refrescos / Aguas / Zumos -->
        <div>
          <h3 class="text-xs tracking-wider uppercase text-brand-blue font-semibold mb-5">Refrescos · Aguas · Zumos</h3>
          <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
            {sinAlcohol.map(marca => {
              const url = logoUrl(marca);
              return (
                <div class="bg-white border border-[var(--color-light-border)] rounded-lg p-3 flex flex-col items-center gap-2 shadow-[var(--shadow-sm)] hover:shadow-[var(--shadow-md)] hover:border-brand-blue/20 transition-all duration-200">
                  <div class="h-12 flex items-center justify-center">
                    {url ? <img src={url} alt={marca} class="h-10 w-auto max-w-full object-contain" loading="lazy" width="60" height="40" /> : <span class="font-display text-sm text-zinc-400">{marca}</span>}
                  </div>
                  <span class="text-[10px] sm:text-[11px] text-[var(--color-text-muted)] font-medium text-center leading-tight">{marca}</span>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Cervezas / Licores / Sidras / Energéticas -->
        <div>
          <h3 class="text-xs tracking-wider uppercase text-brand-red font-semibold mb-5">Cervezas · Licores · Sidras · Energéticas</h3>
          <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
            {conAlcohol.map(marca => {
              const url = logoUrl(marca);
              return (
                <div class="bg-white border border-[var(--color-light-border)] rounded-lg p-3 flex flex-col items-center gap-2 shadow-[var(--shadow-sm)] hover:shadow-[var(--shadow-md)] hover:border-brand-red/20 transition-all duration-200">
                  <div class="h-12 flex items-center justify-center">
                    {url ? <img src={url} alt={marca} class="h-10 w-auto max-w-full object-contain" loading="lazy" width="60" height="40" /> : <span class="font-display text-sm text-zinc-400">{marca}</span>}
                  </div>
                  <span class="text-[10px] sm:text-[11px] text-[var(--color-text-muted)] font-medium text-center leading-tight">{marca}</span>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════ CATÁLOGO CTA — Rojo corporativo ════════════════════ -->
<section class="py-20 sm:py-28 bg-brand-red text-white relative overflow-hidden">
  <!-- Línea geométrica sutil -->
  <div class="absolute bottom-0 right-0 w-64 h-64 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 300 300" class="w-full h-full opacity-[0.07]">
      <line x1="300" y1="0" x2="0" y2="300" stroke="white" stroke-width="1" />
      <line x1="250" y1="0" x2="0" y2="250" stroke="white" stroke-width="1" />
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 reveal">
    <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- Categorías del catálogo -->
      <div>
        <span class="text-white/60 text-xs tracking-[.3em] uppercase font-semibold">Junio 2026</span>
        <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl mt-3 leading-[1.0] uppercase tracking-tight">
          Catálogo Junio 2026
        </h2>
        <ul class="mt-6 space-y-3">
          {[
            { text: 'Refrescos', sub: 'Coca-Cola, Fanta, Nestea, Granini, Don Simon...' },
            { text: 'Aguas', sub: 'Font Vella, Evian, Bezoya, Perrier, San Pellegrino...' },
            { text: 'Cervezas', sub: 'Estrella Damm, Heineken, Mahou, Corona, Guinness...' },
            { text: 'Licores y Sidras', sub: 'Brugal, Larios, Kopparberg, Strongbow, Magners...' },
            { text: 'Energéticas', sub: 'Red Bull, Powerking...' },
          ].map(item => (
            <li class="flex items-start gap-3 text-white/80 text-sm">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-white/30 shrink-0"></span>
              <span><span class="font-semibold text-white">{item.text}</span> — <span class="text-white/50">{item.sub}</span></span>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTA -->
      <div class="text-center md:text-left">
        <p class="text-white/70 text-base sm:text-lg leading-relaxed mb-8">
          47 páginas con precios + IVA actualizados. Descarga gratuita en PDF.
        </p>
        <a href="/catalogo"
          class="inline-flex items-center gap-2 bg-white text-brand-red px-10 py-5 font-bold tracking-wider uppercase text-sm hover:bg-zinc-100 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Ver Catálogo Completo
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════ CONTACTO — Blanco ════════════════════ -->
<section id="contacto" class="py-20 sm:py-28 bg-[var(--color-light)] relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-16">
      <span class="text-brand-red text-xs sm:text-sm tracking-[.3em] uppercase font-semibold">Contacto</span>
      <h2 class="font-display text-3xl sm:text-5xl text-[var(--color-text-dark)] mt-3 leading-[1.1] uppercase tracking-tight">Dónde Estamos</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 reveal">
      <div class="space-y-8">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-brand-red/5 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div>
            <h3 class="text-[var(--color-text-dark)] font-semibold text-sm tracking-wide mb-1">Dirección</h3>
            <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">Polígono Francolí Parcela 15, Nave 5<br>Tarragona 43006</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-brand-red/5 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-brand-red" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <h3 class="text-[var(--color-text-dark)] font-semibold text-sm tracking-wide mb-1">WhatsApp Pedidos</h3>
            <a href="https://wa.me/34600781881" target="_blank" rel="noopener noreferrer"
              class="text-brand-red hover:text-brand-red-dark transition-colors text-lg font-semibold">+34 600 781 881</a>
            <p class="text-[var(--color-text-muted)] text-xs mt-1">Respuesta rápida garantizada</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-brand-blue/5 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <div>
            <h3 class="text-[var(--color-text-dark)] font-semibold text-sm tracking-wide mb-1">Datos Fiscales</h3>
            <p class="text-[var(--color-text-muted)] text-sm">Mehar Company SL</p>
            <p class="text-[var(--color-text-muted)] text-xs">CIF: B05412028</p>
          </div>
        </div>
      </div>

      <!-- Mapa -->
      <div class="bg-[var(--color-light-alt)] border border-[var(--color-light-border)] rounded-2xl overflow-hidden min-h-[280px] relative shadow-[var(--shadow-md)]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2997.4!2d1.2162460!3d41.1133865!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12a3e388f988073d%3A0x19c1aaf477c265c!2sMETRO+CASH+AND+CARRY!5e0!3m2!1ses!2ses!4v1750000000000"
          width="100%" height="100%"
          style="border:0; min-height: 280px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Grupo METRO — Polígono Francolí, Tarragona">
        </iframe>
        <a href="https://www.google.com/maps/place/METRO+CASH+AND+CARRY/@41.1133865,1.216246,17z/"
          target="_blank" rel="noopener noreferrer"
          class="absolute bottom-3 right-3 bg-white/95 text-brand-red hover:text-brand-red-dark text-xs tracking-wider uppercase font-semibold px-3 py-1.5 rounded-lg transition-colors shadow-[var(--shadow-md)]">
          Ver en Google Maps <span aria-hidden="true">&#8599;</span>
        </a>
      </div>
    </div>
  </div>
</section>

</Layout>
