---
import Layout from '../layouts/Layout.astro';

const sinAlcohol = [
  'Coca-Cola','Fanta','Nestea','Nestlé','Don Simon','Granini','Juver',
  'Evian','Font Vella','Bezoya','San Pellegrino','Solán de Cabras','Viladrau','Vichy Catalan','Perrier'
];
const conAlcohol = [
  'Heineken','Corona','Guinness','Estrella Damm','Estrella Galicia','Budweiser','Desperados',
  'Alhambra','Voll-Damm','San Miguel','Mahou','Coors',
  'Red Bull','Powerking',
  'Brugal','Larios','Bodega Pinord','Kopparberg','Strongbow','Magners'
];

const logoUrl = (marca: string) => {
  const file = marca.replace(/ /g, '-').replace(/ñ/g, 'n').replace(/é/g, 'e').replace(/á/g, 'a').replace(/ó/g, 'o').replace(/í/g, 'i').replace(/ú/g, 'u').replace(/'/g, '');
  const logosSvg = [
    'Alhambra','Budweiser','Coca-Cola','Coors','Corona','Desperados',
    'Estrella-Damm','Estrella-Galicia','Evian','Fanta','Granini','Guinness',
    'Heineken','Kopparberg','Mahou','Nestea','Nestle','Perrier',
    'Red-Bull','San-Miguel','San-Pellegrino'
  ];
  const logosPng = [
    'Bezoya','Bodega-Pinord','Brugal','Don-Simon','Font-Vella','Juver','Larios',
    'Magners','Powerking','Solan-de-Cabras','Strongbow','Vichy-Catalan','Viladrau','Voll-Damm'
  ];
  if (logosSvg.includes(file)) return `/logos/${file}.svg`;
  if (logosPng.includes(file)) return `/logos/${file}.png`;
  return null;
};

const topBrands = [
  { name: 'Coca-Cola', url: '/logos/Coca-Cola.svg' },
  { name: 'Heineken', url: '/logos/Heineken.svg' },
  { name: 'Estrella Damm', url: '/logos/Estrella-Damm.svg' },
  { name: 'Red Bull', url: '/logos/Red-Bull.svg' },
  { name: 'Nestlé', url: '/logos/Nestle.svg' },
  { name: 'Font Vella', url: '/logos/Font-Vella.png' },
];
---

<Layout
  title="Inicio"
  description="Grupo METRO — Distribución de bebidas a restauración y supermercados en Tarragona. +50 marcas líderes: Coca-Cola, Estrella Damm, Heineken, Red Bull y más."
  ogImage="/logo.jpg"
>

<!-- ═══════ HERO ═══════ -->
<section class="hero-bg min-h-[calc(100vh-4rem)] flex items-center relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full bg-brand-red/3 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-60 h-60 rounded-full bg-brand-blue/3 blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-16 md:py-24 relative z-10">
    <div class="grid md:grid-cols-2 gap-8 md:gap-12 lg:gap-16 items-center">

      <!-- Logo Grupo Metro — visible arriba en móvil, derecha en desktop -->
      <div class="flex justify-center md:hidden mb-2">
        <div class="relative max-w-[200px]">
          <div class="absolute inset-0 bg-brand-blue/10 rounded-3xl blur-2xl" aria-hidden="true"></div>
          <img
            src="/logo.jpg"
            alt="Logo Grupo METRO — Distribuidora de bebidas en Tarragona"
            class="relative w-full mx-auto rounded-2xl"
            width="400" height="200"
            loading="eager"
          />
        </div>
      </div>

      <!-- Texto -->
      <div>
        <div class="inline-flex items-center gap-2 bg-brand-red/10 border border-brand-red/20 rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 rounded-full bg-brand-red animate-pulse"></span>
          <span class="text-brand-red text-xs tracking-wider uppercase font-medium">Distribución · Tarragona</span>
        </div>

        <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl leading-[0.95] text-balance uppercase">
          Líderes en<br>
          <span class="text-brand-red">Distribución</span>
        </h1>

        <p class="text-zinc-400 mt-6 text-base sm:text-lg max-w-lg leading-relaxed">
          Llevamos las mejores marcas a restaurantes, bares y supermercados de Tarragona.
          Coca-Cola, Estrella Damm, Heineken, Red Bull y mucho más.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mt-8">
          <a href="/catalogo"
            class="group bg-brand-red text-white px-8 py-4 font-bold tracking-wider uppercase text-sm text-center hover:bg-brand-red-light transition-all duration-200 pulse-ring">
            <span class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              Ver Catálogo
            </span>
          </a>
          <a href="https://wa.me/34600781881" target="_blank" rel="noopener noreferrer"
            class="group border border-brand-blue/40 bg-brand-blue/5 px-8 py-4 text-sm tracking-wider uppercase text-center hover:border-brand-blue/60 hover:bg-brand-blue/10 transition-all duration-200">
            <span class="flex items-center justify-center gap-2 text-brand-blue-light group-hover:text-brand-blue-light transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </span>
          </a>
        </div>
      </div>

      <!-- Visual desktop: Logo + marcas top -->
      <div class="hidden md:block">
        <div class="relative max-w-sm mx-auto">
          <div class="absolute inset-0 bg-brand-blue/10 rounded-3xl blur-2xl" aria-hidden="true"></div>
          <img src="/logo.jpg" alt="Logo Grupo METRO — Distribuidora de bebidas en Tarragona"
            class="relative w-full mx-auto rounded-2xl" width="400" height="200" loading="eager" />
        </div>
        <div class="grid grid-cols-3 gap-3 mt-10">
          {topBrands.map(brand => (
            <div class="bg-zinc-900/80 border border-zinc-800/80 rounded-xl p-4 flex items-center justify-center hover:border-brand-red/30 transition-all duration-200 h-16">
              <img src={brand.url} alt={brand.name} class="h-10 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity" loading="lazy" width="80" height="40" />
            </div>
          ))}
        </div>
      </div>

      <!-- Visual móvil: logos de marcas debajo del texto -->
      <div class="md:hidden">
        <div class="grid grid-cols-3 gap-2 mt-4">
          {topBrands.map(brand => (
            <div class="bg-zinc-900/80 border border-zinc-800/80 rounded-xl p-3 flex items-center justify-center hover:border-brand-red/30 transition-all duration-200 h-12">
              <img src={brand.url} alt={brand.name} class="h-7 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity" loading="lazy" width="80" height="40" />
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══════ QUIÉNES SOMOS ═══════ -->
<section class="py-20 sm:py-28 bg-black relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px section-divider" aria-hidden="true"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <span class="text-brand-red text-xs sm:text-sm tracking-[.3em] uppercase">Quiénes Somos</span>
    <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl mt-4 mb-4 text-balance leading-[1.05] uppercase">Distribución que<br>Impulsa tu Negocio</h2>
    <p class="text-zinc-500 text-base max-w-2xl mb-14">
      Somos el puente entre las grandes marcas y tu establecimiento. Rapidez, cercanía y un catálogo que no para de crecer.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 lg:gap-8">
      <div class="group bg-zinc-900/50 border border-zinc-800/80 rounded-xl p-6 sm:p-8 hover:border-brand-red/30 transition-all duration-300 card-lift">
        <div class="w-12 h-12 rounded-lg bg-brand-red/10 flex items-center justify-center mb-5 group-hover:bg-brand-red/15 transition-colors">
          <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        </div>
        <div class="text-4xl font-display text-brand-red mb-2">+50</div>
        <p class="text-zinc-400 text-sm leading-relaxed">Marcas oficiales con las que colaboramos directamente, desde refrescos hasta licores premium.</p>
      </div>
      <div class="group bg-zinc-900/50 border border-zinc-800/80 rounded-xl p-6 sm:p-8 hover:border-brand-blue/30 transition-all duration-300 card-lift glow-blue">
        <div class="w-12 h-12 rounded-lg bg-brand-blue/10 flex items-center justify-center mb-5 group-hover:bg-brand-blue/15 transition-colors">
          <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div class="text-4xl font-display text-brand-blue mb-2">Tarragona</div>
        <p class="text-zinc-400 text-sm leading-relaxed">Cobertura completa en toda la provincia: restauración, bares, supermercados y tiendas de conveniencia.</p>
      </div>
      <div class="group bg-zinc-900/50 border border-zinc-800/80 rounded-xl p-6 sm:p-8 hover:border-brand-red/30 transition-all duration-300 card-lift">
        <div class="w-12 h-12 rounded-lg bg-brand-red/10 flex items-center justify-center mb-5 group-hover:bg-brand-red/15 transition-colors">
          <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div class="text-4xl font-display text-brand-red mb-2">24/7</div>
        <p class="text-zinc-400 text-sm leading-relaxed">Pedidos por WhatsApp con respuesta ágil. Tu negocio no espera, nosotros tampoco.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ MARCAS ═══════ -->
<section class="py-16 sm:py-28 bg-zinc-950 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 sm:mb-12">
    <span class="text-brand-red text-xs sm:text-sm tracking-[.3em] uppercase">Colaboraciones Oficiales</span>
    <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl mt-3 sm:mt-4 leading-[1.05] uppercase">Marcas que<br>Distribuimos</h2>
  </div>

  <!-- CINTA SUPERIOR -->
  <div class="mb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-4">
      <span class="text-xs tracking-wider uppercase text-brand-blue-light font-semibold">Refrescos · Aguas · Zumos</span>
    </div>
    <div class="marquee-pause py-6 border-y border-brand-blue/20 marquee-mask">
      <div class="animate-marquee flex gap-4 w-max">
        {[...sinAlcohol, ...sinAlcohol].map((marca) => {
          const url = logoUrl(marca);
          return (
            <div class="bg-zinc-900 border border-zinc-800/80 rounded-lg sm:rounded-xl px-3 sm:px-5 py-3 sm:py-4 flex flex-col items-center gap-2 sm:gap-3 hover:border-brand-blue/50 hover:bg-zinc-900/80 transition-all duration-300 shrink-0 w-[110px] sm:w-[140px]">
              <div class="h-16 sm:h-20 w-full flex items-center justify-center">
                {url ? (
                  <img src={url} alt={marca} class="h-16 sm:h-20 w-auto max-w-full object-contain" loading="lazy" width="80" height="64" />
                ) : (
                  <span class="font-display text-lg sm:text-2xl text-zinc-600 tracking-wide leading-none text-center">{marca}</span>
                )}
              </div>
              <span class="text-[10px] sm:text-xs text-zinc-500 font-medium tracking-wide text-center leading-tight">{marca}</span>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- CINTA INFERIOR -->
  <div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-4">
      <span class="text-xs tracking-wider uppercase text-brand-red font-semibold">Cervezas · Licores · Sidras · Energéticas</span>
    </div>
    <div class="marquee-pause py-6 border-y border-brand-red/20 marquee-mask">
      <div class="animate-marquee-reverse flex gap-4 w-max">
        {[...conAlcohol, ...conAlcohol].map((marca) => {
          const url = logoUrl(marca);
          return (
            <div class="bg-zinc-900 border border-zinc-800/80 rounded-lg sm:rounded-xl px-3 sm:px-5 py-3 sm:py-4 flex flex-col items-center gap-2 sm:gap-3 hover:border-brand-red/40 hover:bg-zinc-900/80 transition-all duration-300 shrink-0 w-[110px] sm:w-[140px]">
              <div class="h-16 sm:h-20 w-full flex items-center justify-center">
                {url ? (
                  <img src={url} alt={marca} class="h-16 sm:h-20 w-auto max-w-full object-contain" loading="lazy" width="80" height="64" />
                ) : (
                  <span class="font-display text-lg sm:text-2xl text-zinc-600 tracking-wide leading-none text-center">{marca}</span>
                )}
              </div>
              <span class="text-[10px] sm:text-xs text-zinc-500 font-medium tracking-wide text-center leading-tight">{marca}</span>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<!-- ═══════ CATÁLOGO CTA ═══════ -->
<section class="py-20 sm:py-28 bg-brand-red text-white relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-10 right-10 w-40 h-40 rounded-full bg-white/5 blur-2xl"></div>
    <div class="absolute bottom-10 left-10 w-60 h-60 rounded-full bg-white/5 blur-3xl"></div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <span class="text-white/60 text-xs sm:text-sm tracking-[.3em] uppercase">Junio 2026</span>
    <h2 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl mt-4 leading-[0.95] uppercase">Catálogo<br class="sm:hidden"> Junio 2026</h2>
    <p class="text-lg sm:text-xl mt-5 max-w-xl mx-auto text-white/70 leading-relaxed">
      Explora todos nuestros productos con precios actualizados. Nuevas incorporaciones cada mes.
